{
	"info": {
		"_postman_id": "bc2794a1-9318-4933-a805-e2e5d598b4c3",
		"name": "Adobe IO - OAuth",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "790650"
	},
	"item": [
		{
			"name": "POST - Get Access Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var data = JSON.parse(responseBody);",
							"postman.setEnvironmentVariable(\"access_token\", data.access_token);",
							"postman.setEnvironmentVariable(\"ACCESS_TOKEN\", data.access_token);",
							"postman.setEnvironmentVariable(\"IMS_TOKEN\", data.access_token);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "https://ims-na1.adobelogin.com/ims/token/v2?grant_type=client_credentials&client_id={{API_KEY}}&client_secret={{CLIENT_SECRET}}&scope=openid,session,AdobeID,read_organizations,additional_info.projectedProductContext, ff_apis, firefly_api",
					"protocol": "https",
					"host": [
						"ims-na1",
						"adobelogin",
						"com"
					],
					"path": [
						"ims",
						"token",
						"v2"
					],
					"query": [
						{
							"key": "grant_type",
							"value": "client_credentials"
						},
						{
							"key": "client_id",
							"value": "{{API_KEY}}"
						},
						{
							"key": "client_secret",
							"value": "{{CLIENT_SECRET}}"
						},
						{
							"key": "scope",
							"value": "openid,session,AdobeID,read_organizations,additional_info.projectedProductContext, ff_apis, firefly_api"
						}
					]
				}
			},
			"response": []
		}
	]
}